// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../generated/client"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum DealStatus {
  new_lead
  contacted
  valuation
  offer_made
  under_offer
  exchanged
  completed
  rejected
  withdrawn
}

enum DealSource {
  intake_form
  scout_lead
  manual
  referral
  auction
  middleman
}

enum SellerType {
  probate
  chain_break
  short_lease
  repossession
  relocation
  standard
}

enum Verdict {
  STRONG
  VIABLE
  THIN
  PASS
  INSUFFICIENT_DATA
}

// ─── Founder Action Centre ─────────────────────────────────

enum AgentName {
  scout
  appraiser
  counsel
  marketer
  liaison
  cto
  orchestrator
  system
}

enum ActionType {
  review_leads
  approve_offer
  chain_break_alert
  sla_breach
  legal_flag
  review_campaign
  ceo_escalation
  golden_window
  dispatch_campaign
  general
}

enum CampaignStatus {
  draft
  active
  paused
  completed
  archived
}

enum ActionPriority {
  critical
  high
  medium
  low
}

enum ActionStatus {
  pending
  in_progress
  completed
  dismissed
  expired
}

// ─── Feedback & Eval System ────────────────────────────────

enum FeedbackTargetType {
  scout_lead
  avm_result
  outreach_template
  outreach_campaign
  legal_step
  deal
  founder_action
  campaign
}

enum EvalType {
  lead_scoring
  avm_confidence
  outreach_quality
  deal_quality
  campaign_targeting
}

enum ParseStatus {
  pending
  parsed
  failed
  manual_review
}

model Deal {
  id                        String     @id @default(cuid())
  address                   String
  postcode                  String
  propertyType              String
  bedrooms                  Int?
  sellerType                SellerType @default(standard)
  source                    DealSource @default(manual)
  status                    DealStatus @default(new_lead)
  askingPricePence          Int?
  ourOfferPence             Int?
  estimatedMarketValuePence Int?
  marginPercent             Float?
  verdict                   Verdict?
  sellerName                String?
  sellerEmail               String?
  sellerPhone               String?
  notes                     String?    @db.Text
  stageEnteredAt            DateTime   @default(now())
  convertedFromLeadId       String?
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt

  // Founder Action Centre fields
  suggestedNextAction   String?   @db.Text   // JSON: { action, reasoning, agent }
  goldenWindowExpiresAt DateTime?            // Probate/chain break deadline
  mortgageExpiryDate    DateTime?            // Vendor mortgage expiry for chain breaks

  // Calendly booking
  calendlyBookingLink String?
  calendlyEventAt     DateTime?

  activities     DealActivity[]
  legalSteps     LegalStep[]
  legalDocuments LegalDocument[]
  avmResults     AvmResult[]
  dealUpdates    DealUpdate[]
  trackToken     TrackToken?

  @@index([status])
  @@index([postcode])
  @@index([sellerType])
}

model DealActivity {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  action    String
  detail    String?  @db.Text
  userId    String?
  createdAt DateTime @default(now())

  @@index([dealId])
}

model ScoutLead {
  id                   String   @id @default(cuid())
  runDate              DateTime
  source               String
  address              String
  postcode             String
  leadType             String
  estimatedEquityPence Int?
  contactName          String?
  contactPhone         String?
  contactEmail         String?
  leadScore            Int
  verdict              Verdict
  marketTrend          String?
  sourceTrail          String?
  rawPayload           Json?
  status               String   @default("new")
  convertedDealId      String?
  createdAt            DateTime @default(now())

  evalConfigVersion Int?     // version of lead_scoring eval used

  // Calendly booking (pre-conversion — once we send the link to a lead)
  calendlyBookingLink String?

  // Targeted campaign
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  whatsAppIntake WhatsAppIntake?

  @@index([status])
  @@index([leadScore])
  @@index([postcode])
  @@index([campaignId])
}

model WhatsAppIntake {
  id               String      @id @default(cuid())
  source           String      // "bridge" | "paste" | "share_sheet" | "email"
  groupName        String?
  senderName       String?
  senderPhone      String?
  rawText          String      @db.Text
  mediaUrls        String[]    @default([])
  parsedFields     Json?
  parsedConfidence Float?
  parseStatus      ParseStatus @default(pending)
  parseError       String?
  scoutLeadId      String?     @unique
  scoutLead        ScoutLead?  @relation(fields: [scoutLeadId], references: [id])
  founderActionId  String?
  receivedAt       DateTime    @default(now())
  processedAt      DateTime?

  @@index([parseStatus])
  @@index([source])
  @@index([receivedAt])
}

model AvmResult {
  id           String   @id @default(cuid())
  dealId       String?
  deal         Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  postcode     String
  propertyType String
  riskScore    Int
  resultJson   Json
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  evalConfigVersion Int?     // version of avm_confidence eval used

  @@index([dealId])
  @@index([postcode, propertyType])
}

model LegalStep {
  id          String    @id @default(cuid())
  dealId      String
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stepKey     String
  completed   Boolean   @default(false)
  completedAt DateTime?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([dealId, stepKey])
  @@index([dealId])
}

model LegalDocument {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stepKey   String
  filename  String
  url       String
  mimeType  String?
  sizeByte  Int?
  createdAt DateTime @default(now())

  @@index([dealId])
}

model Contact {
  id       String   @id @default(cuid())
  type     String
  name     String
  company  String?
  email    String?
  phone    String?
  location String?
  notes    String?  @db.Text
  tags     String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outreachRecipients OutreachRecipient[]

  @@index([type])
}

model OutreachTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String   @db.Text
  type      String
  sequence  Int      @default(1)
  delayDays Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OutreachCampaign {
  id          String   @id @default(cuid())
  name        String
  templateIds String[]
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Targeted campaign link
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  recipients OutreachRecipient[]

  @@index([campaignId])
}

// ─── Targeted Campaigns (Founder-defined geography + filters) ────

model Campaign {
  id               String         @id @default(cuid())
  name             String
  createdBy        String
  status           CampaignStatus @default(draft)
  postcodeArea     String         // e.g. "M1", "B15", "LS6"
  radiusMiles      Int            @default(3)
  propertyTypes    String[]       // ["terraced_house", "semi_detached", "flat"]
  minPricePence    Int?
  maxPricePence    Int?
  sellerTypes      String[]       // ["probate", "chain_break", ...]
  minLeadScore     Int            @default(50)
  outreachChannels String[]       // ["estate_agents", "solicitors", "direct_mail"]
  budgetPence      Int?
  dailyCap         Int            @default(20)
  targetEndDate    DateTime?

  // Funnel metrics
  leadsFound     Int @default(0)
  leadsQualified Int @default(0)
  outreachSent   Int @default(0)
  replies        Int @default(0)
  dealsCreated   Int @default(0)

  launchedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  scoutLeads        ScoutLead[]
  outreachCampaigns OutreachCampaign[]

  @@index([status])
  @@index([postcodeArea])
}

model OutreachRecipient {
  id          String           @id @default(cuid())
  campaignId  String
  campaign    OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentStep Int              @default(0)
  lastSentAt  DateTime?
  status      String           @default("pending")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([campaignId])
  @@index([contactId])
}

// ─── Founder Action Centre ─────────────────────────────────

model AgentEvent {
  id            String    @id @default(cuid())
  agent         AgentName
  eventType     String              // e.g. "leads_created", "avm_completed"
  summary       String              // human-readable: "Scout created 12 leads (8 STRONG)"
  payload       Json?               // structured data for downstream use
  dealId        String?             // optional link to deal
  count         Int       @default(1)
  pipelineRunId String?             // groups events from one overnight run
  createdAt     DateTime  @default(now())

  @@index([agent])
  @@index([createdAt])
  @@index([dealId])
  @@index([pipelineRunId])
}

model FounderAction {
  id           String         @id @default(cuid())
  type         ActionType
  priority     ActionPriority @default(medium)
  status       ActionStatus   @default(pending)
  title        String
  description  String?        @db.Text
  agent        AgentName
  dealId       String?
  metadata     Json?          // type-specific structured data
  assignedTo   String?        // Clerk userId (null = both founders)
  resolvedBy   String?
  resolvedAt   DateTime?
  expiresAt    DateTime?
  agentEventId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, priority])
  @@index([dealId])
  @@index([type])
  @@index([createdAt])
}

// ─── Feedback & Eval System ────────────────────────────────

model FounderFeedback {
  id               String             @id @default(cuid())
  targetType       FeedbackTargetType
  targetId         String              // polymorphic FK to the rated entity
  founderId        String              // Clerk userId
  rating           Int                 // 1-5 stars
  overrides        Json?               // { leadScore: 85, verdict: "STRONG", ... }
  notes            String?             @db.Text
  markedAsTemplate Boolean             @default(false) // "perfect template" flag
  createdAt        DateTime            @default(now())

  @@index([targetType, targetId])
  @@index([founderId])
  @@index([createdAt])
}

model EvalConfig {
  id          String    @id @default(cuid())
  evalType    EvalType
  version     Int
  config      Json      // the weights/thresholds/params
  description String?
  activatedAt DateTime? // null = draft, set = live version
  activatedBy String?   // Clerk userId
  createdAt   DateTime  @default(now())

  @@unique([evalType, version])
  @@index([evalType, activatedAt])
}

model OutreachHold {
  id              String    @id @default(cuid())
  recipientId     String
  campaignId      String?
  templateId      String?
  recipientType   String    // "individual" | "estate_agent" | "solicitor"
  recipientName   String?
  recipientEmail  String?
  renderedSubject String
  renderedBody    String    @db.Text
  status          String    @default("held") // held | approved | rejected | sent
  reviewedBy      String?
  reviewedAt      DateTime?
  editedBody      String?   @db.Text
  createdAt       DateTime  @default(now())

  @@index([status])
  @@index([campaignId])
}

// ─── Auctions ───────────────────────────────────────────────

model AuctionLot {
  id                 String   @id @default(cuid())
  sourceHouse        String              // e.g. "auction_house_uk", "savills", "clive_emson"
  sourceLotRef       String              // the auction house's own lot ref / number
  auctionDate        DateTime
  address            String
  postcode           String
  propertyType       String              // terraced_house | semi_detached | detached | flat | commercial | land | other
  guidePriceMinPence Int?
  guidePriceMaxPence Int?
  sold               Boolean  @default(false)
  soldPricePence     Int?
  lotUrl             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([sourceHouse, sourceLotRef])
  @@index([auctionDate])
  @@index([postcode])
}

enum QuoteStatus {
  draft
  processing
  quoted
  accepted
  declined
  expired
  converted_to_deal
}

enum QuoteRole {
  agent
  seller
  solicitor
  other
}

model QuoteRequest {
  id              String      @id @default(cuid())
  source          String      // "public_web", "agent_portal", "api"
  referralCode    String?
  contactName     String
  contactEmail    String
  contactPhone    String?
  role            QuoteRole
  firmName        String?
  address         String
  postcode        String
  propertyType    String?
  bedrooms        Int?
  condition       Int?        // 1-10
  askingPricePence Int?
  sellerSituation String?     // probate / chain_break / etc
  urgencyDays     Int?
  notes           String?     @db.Text
  chatTranscript  Json?
  status          QuoteStatus @default(draft)
  offerId         String?     @unique
  offer           QuoteOffer? @relation(fields: [offerId], references: [id])
  dealUpdates     DealUpdate[]
  trackToken      TrackToken?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([postcode])
  @@index([referralCode])
}

model QuoteOffer {
  id                           String        @id @default(cuid())
  estimatedMarketValueMinPence Int
  estimatedMarketValueMaxPence Int
  offerPence                   Int
  offerPercentOfAvm            Float
  confidenceScore              Float
  completionDays               Int
  reasoning                    Json
  lockedUntil                  DateTime
  pdfUrl                       String?
  acceptedAt                   DateTime?
  quoteRequest                 QuoteRequest?
  createdAt                    DateTime      @default(now())
}

// Transparent deal-timeline event. Every state change a seller / agent /
// solicitor would care about is written here and emailed to all
// parties on the deal. Visible publicly via /track/<trackToken>.
model DealUpdate {
  id            String           @id @default(cuid())
  dealId        String?
  deal          Deal?            @relation(fields: [dealId], references: [id])
  quoteRequestId String?
  quoteRequest  QuoteRequest?    @relation(fields: [quoteRequestId], references: [id])
  kind          DealUpdateKind
  title         String           // 1-line public-friendly summary
  detail        String?          @db.Text
  metadata      Json?            // structured data (e.g. survey result, ETA)
  visibility    DealUpdateVisibility @default(public)
  notifiedTo    String[]         @default([])  // emails dispatched to
  notifiedBy    String?          // user/agent id that triggered the update
  createdAt     DateTime         @default(now())

  @@index([dealId, createdAt])
  @@index([quoteRequestId, createdAt])
  @@index([kind])
}

enum DealUpdateKind {
  quote_requested
  offer_sent
  offer_accepted
  offer_declined
  offer_expired
  solicitor_instructed
  searches_ordered
  survey_scheduled
  survey_completed
  enquiries_raised
  enquiries_resolved
  exchange_target_set
  exchanged
  completion_target_set
  completed
  delay
  founder_review
  resale_listed
  note
}

enum DealUpdateVisibility {
  public          // visible on /track/<token>
  agent_only      // dashboard only, agents
  internal        // founder + Paperclip agents only
}

// Public tracker token — sellers / agents share this URL to see live
// deal status without logging in.
model TrackToken {
  id            String   @id @default(cuid())
  token         String   @unique           // url-safe, 32 chars
  quoteRequestId String?  @unique
  quoteRequest  QuoteRequest? @relation(fields: [quoteRequestId], references: [id])
  dealId        String?  @unique
  deal          Deal?    @relation(fields: [dealId], references: [id])
  createdAt     DateTime @default(now())
  lastViewedAt  DateTime?
  viewCount     Int      @default(0)

  @@index([quoteRequestId])
  @@index([dealId])
}

model AgentAccount {
  id             String    @id @default(cuid())
  email          String    @unique
  contactName    String
  firmName       String
  phone          String?
  postcode       String?
  referralCode   String    @unique
  tier           String    @default("partner") // partner | preferred | elite
  totalReferrals Int       @default(0)
  totalDeals     Int       @default(0)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([referralCode])
}

model EstateAgentContact {
  id                    String    @id @default(cuid())
  firmName              String
  contactName           String?
  email                 String?   @unique
  phone                 String?
  address               String?
  postcode              String?
  rightmoveListingCount Int?
  googleRating          Float?
  referralCode          String?   @unique
  outreachSent          Boolean   @default(false)
  lastOutreachAt        DateTime?
  lastClickAt           DateTime?
  quotesRequested       Int       @default(0)
  dealsCompleted        Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([postcode])
  @@index([referralCode])
}
