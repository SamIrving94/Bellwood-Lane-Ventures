// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../generated/client"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum DealStatus {
  new_lead
  contacted
  valuation
  offer_made
  under_offer
  exchanged
  completed
  rejected
  withdrawn
}

enum DealSource {
  intake_form
  scout_lead
  manual
  referral
  auction
  middleman
}

enum SellerType {
  probate
  chain_break
  short_lease
  repossession
  relocation
  standard
}

enum Verdict {
  STRONG
  VIABLE
  THIN
  PASS
  INSUFFICIENT_DATA
}

// ─── Founder Action Centre ─────────────────────────────────

enum AgentName {
  scout
  appraiser
  counsel
  marketer
  liaison
  cto
  orchestrator
  system
}

enum ActionType {
  review_leads
  approve_offer
  chain_break_alert
  sla_breach
  legal_flag
  review_campaign
  ceo_escalation
  golden_window
  general
}

enum ActionPriority {
  critical
  high
  medium
  low
}

enum ActionStatus {
  pending
  in_progress
  completed
  dismissed
  expired
}

// ─── Feedback & Eval System ────────────────────────────────

enum FeedbackTargetType {
  scout_lead
  avm_result
  outreach_template
  outreach_campaign
  legal_step
  deal
  founder_action
}

enum EvalType {
  lead_scoring
  avm_confidence
  outreach_quality
  deal_quality
}

model Deal {
  id                        String     @id @default(cuid())
  address                   String
  postcode                  String
  propertyType              String
  bedrooms                  Int?
  sellerType                SellerType @default(standard)
  source                    DealSource @default(manual)
  status                    DealStatus @default(new_lead)
  askingPricePence          Int?
  ourOfferPence             Int?
  estimatedMarketValuePence Int?
  marginPercent             Float?
  verdict                   Verdict?
  sellerName                String?
  sellerEmail               String?
  sellerPhone               String?
  notes                     String?    @db.Text
  stageEnteredAt            DateTime   @default(now())
  convertedFromLeadId       String?
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt

  // Founder Action Centre fields
  suggestedNextAction   String?   @db.Text   // JSON: { action, reasoning, agent }
  goldenWindowExpiresAt DateTime?            // Probate/chain break deadline
  mortgageExpiryDate    DateTime?            // Vendor mortgage expiry for chain breaks

  // Calendly booking
  calendlyBookingLink String?
  calendlyEventAt     DateTime?

  activities     DealActivity[]
  legalSteps     LegalStep[]
  legalDocuments LegalDocument[]
  avmResults     AvmResult[]

  @@index([status])
  @@index([postcode])
  @@index([sellerType])
}

model DealActivity {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  action    String
  detail    String?  @db.Text
  userId    String?
  createdAt DateTime @default(now())

  @@index([dealId])
}

model ScoutLead {
  id                   String   @id @default(cuid())
  runDate              DateTime
  source               String
  address              String
  postcode             String
  leadType             String
  estimatedEquityPence Int?
  contactName          String?
  contactPhone         String?
  contactEmail         String?
  leadScore            Int
  verdict              Verdict
  marketTrend          String?
  sourceTrail          String?
  rawPayload           Json?
  status               String   @default("new")
  convertedDealId      String?
  createdAt            DateTime @default(now())

  evalConfigVersion Int?     // version of lead_scoring eval used

  // Calendly booking (pre-conversion — once we send the link to a lead)
  calendlyBookingLink String?

  @@index([status])
  @@index([leadScore])
  @@index([postcode])
}

model AvmResult {
  id           String   @id @default(cuid())
  dealId       String?
  deal         Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  postcode     String
  propertyType String
  riskScore    Int
  resultJson   Json
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  evalConfigVersion Int?     // version of avm_confidence eval used

  @@index([dealId])
  @@index([postcode, propertyType])
}

model LegalStep {
  id          String    @id @default(cuid())
  dealId      String
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stepKey     String
  completed   Boolean   @default(false)
  completedAt DateTime?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([dealId, stepKey])
  @@index([dealId])
}

model LegalDocument {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stepKey   String
  filename  String
  url       String
  mimeType  String?
  sizeByte  Int?
  createdAt DateTime @default(now())

  @@index([dealId])
}

model Contact {
  id       String   @id @default(cuid())
  type     String
  name     String
  company  String?
  email    String?
  phone    String?
  location String?
  notes    String?  @db.Text
  tags     String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outreachRecipients OutreachRecipient[]

  @@index([type])
}

model OutreachTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String   @db.Text
  type      String
  sequence  Int      @default(1)
  delayDays Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OutreachCampaign {
  id          String   @id @default(cuid())
  name        String
  templateIds String[]
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recipients OutreachRecipient[]
}

model OutreachRecipient {
  id          String           @id @default(cuid())
  campaignId  String
  campaign    OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentStep Int              @default(0)
  lastSentAt  DateTime?
  status      String           @default("pending")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([campaignId])
  @@index([contactId])
}

// ─── Founder Action Centre ─────────────────────────────────

model AgentEvent {
  id            String    @id @default(cuid())
  agent         AgentName
  eventType     String              // e.g. "leads_created", "avm_completed"
  summary       String              // human-readable: "Scout created 12 leads (8 STRONG)"
  payload       Json?               // structured data for downstream use
  dealId        String?             // optional link to deal
  count         Int       @default(1)
  pipelineRunId String?             // groups events from one overnight run
  createdAt     DateTime  @default(now())

  @@index([agent])
  @@index([createdAt])
  @@index([dealId])
  @@index([pipelineRunId])
}

model FounderAction {
  id           String         @id @default(cuid())
  type         ActionType
  priority     ActionPriority @default(medium)
  status       ActionStatus   @default(pending)
  title        String
  description  String?        @db.Text
  agent        AgentName
  dealId       String?
  metadata     Json?          // type-specific structured data
  assignedTo   String?        // Clerk userId (null = both founders)
  resolvedBy   String?
  resolvedAt   DateTime?
  expiresAt    DateTime?
  agentEventId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, priority])
  @@index([dealId])
  @@index([type])
  @@index([createdAt])
}

// ─── Feedback & Eval System ────────────────────────────────

model FounderFeedback {
  id               String             @id @default(cuid())
  targetType       FeedbackTargetType
  targetId         String              // polymorphic FK to the rated entity
  founderId        String              // Clerk userId
  rating           Int                 // 1-5 stars
  overrides        Json?               // { leadScore: 85, verdict: "STRONG", ... }
  notes            String?             @db.Text
  markedAsTemplate Boolean             @default(false) // "perfect template" flag
  createdAt        DateTime            @default(now())

  @@index([targetType, targetId])
  @@index([founderId])
  @@index([createdAt])
}

model EvalConfig {
  id          String    @id @default(cuid())
  evalType    EvalType
  version     Int
  config      Json      // the weights/thresholds/params
  description String?
  activatedAt DateTime? // null = draft, set = live version
  activatedBy String?   // Clerk userId
  createdAt   DateTime  @default(now())

  @@unique([evalType, version])
  @@index([evalType, activatedAt])
}

model OutreachHold {
  id              String    @id @default(cuid())
  recipientId     String
  campaignId      String?
  templateId      String?
  recipientType   String    // "individual" | "estate_agent" | "solicitor"
  recipientName   String?
  recipientEmail  String?
  renderedSubject String
  renderedBody    String    @db.Text
  status          String    @default("held") // held | approved | rejected | sent
  reviewedBy      String?
  reviewedAt      DateTime?
  editedBody      String?   @db.Text
  createdAt       DateTime  @default(now())

  @@index([status])
  @@index([campaignId])
}

// ─── Auctions ───────────────────────────────────────────────

model AuctionLot {
  id                 String   @id @default(cuid())
  sourceHouse        String              // e.g. "auction_house_uk", "savills", "clive_emson"
  sourceLotRef       String              // the auction house's own lot ref / number
  auctionDate        DateTime
  address            String
  postcode           String
  propertyType       String              // terraced_house | semi_detached | detached | flat | commercial | land | other
  guidePriceMinPence Int?
  guidePriceMaxPence Int?
  sold               Boolean  @default(false)
  soldPricePence     Int?
  lotUrl             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([sourceHouse, sourceLotRef])
  @@index([auctionDate])
  @@index([postcode])
}
